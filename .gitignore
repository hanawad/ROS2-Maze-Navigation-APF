*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg-info/
dist/
*.egg

# Editor and OS artifacts
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Gazebo simulation cache and logs
~/.gz/
*.bag
*.db3